{
  "name": "paperdoc",
  "version": "0.1.0",
  "description": "Medical Scribe AI — Local-first SOAP note generation from doctor-patient conversations",
  "type": "module",
  "bin": {
    "paperdoc": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts run",
    "download-model": "bun run src/cli.ts download-model",
    "build": "bun build --target=bun --outdir=dist src/cli.ts src/server/index.ts",
    "appimage": "bash build/appimage.sh"
  },
  "dependencies": {
    "@qvac/sdk": "^0.13.3",
    "hono": "^4.6.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
